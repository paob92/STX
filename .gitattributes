# Normalización de fin de línea
* text=auto

# Archivos de texto de Unity (para diffs/merges legibles)
*.cs      text diff=csharp
*.uxml    text
*.uss     text
*.asmdef  text
*.json    text
*.md      text
*.shader  text
*.cginc   text

# Escenas / prefabs / assets de Unity (YAML de texto)
*.unity   text
*.prefab  text
*.mat     text
*.asset   text
*.meta    text
*.controller text
*.anim    text

# Binarios (no hacer diff textual)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.psd     binary
*.tga     binary
*.fbx     binary
*.obj     binary
*.blend   binary
*.wav     binary
*.mp3     binary
*.ogg     binary
*.ttf     binary
*.otf     binary
*.dll     binary
*.aif     binary
*.aiff    binary
